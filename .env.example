# Local development secrets template. Copy to .env or export these in your shell.
# Do not put real keys in committed yml files.

# Default OpenAI-compatible provider used by Spring AI auto-config and current embedding config.
# In the current project this may point to Gemini OpenAI-compatible endpoint.
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
OPENAI_API_KEY=replace-me
OPENAI_CHAT_MODEL=gemini-flash-latest
OPENAI_EMBEDDING_MODEL=gemini-embedding-2
# Must match docs/dev-ops/pgvector/sql/init.sql: embedding VECTOR(1536).
OPENAI_EMBEDDING_DIMENSIONS=1536

# DeepSeek is recommended for dynamic ai_client_api / ai_client_model DB config,
# not for global spring.ai.openai when embedding still uses that global config.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=replace-me
DEEPSEEK_CHAT_MODEL=deepseek-chat
